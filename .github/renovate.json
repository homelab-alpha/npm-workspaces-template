{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", ":semanticCommits", ":rebaseStalePrs"],
  "dependencyDashboard": true,
  "osvVulnerabilityAlerts": true,
  "platformAutomerge": true,
  "prConcurrentLimit": 0,
  "prHourlyLimit": 0,
  "timezone": "Europe/Amsterdam",
  "schedule": ["after 9am and before 5pm"],
  "rangeStrategy": "bump",
  "ignorePaths": ["docker/compose.prod.yml"],
  "assignees": ["homelab-alpha"],
  "automergeSchedule": ["after 9am and before 5pm on weekdays"],
  "automergeType": "squash",
  "packageRules": [
    {
      "description": "Label updates based on type",
      "matchUpdateTypes": ["major", "minor", "patch"],
      "addLabels": ["{{{updateType}}}"]
    },
    {
      "description": "Automerge patch updates",
      "matchUpdateTypes": ["patch", "digest", "pin"],
      "automerge": true
    },
    {
      "description": "Manual review for non-patch updates",
      "matchUpdateTypes": ["minor", "major"],
      "automerge": false
    },
    {
      "description": "Group dependency labels",
      "matchDepTypes": ["dependencies", "require"],
      "addLabels": ["dependencies"]
    },
    {
      "description": "Group devDependency labels",
      "matchDepTypes": ["devDependencies", "require-dev"],
      "addLabels": ["dev dependencies"]
    },
    {
      "description": "Group CI/GitHub Action labels",
      "matchDepTypes": ["action", "plugin"],
      "addLabels": ["ci"]
    },
    {
      "description": "Keep Node.js on major version 22",
      "matchPackagePatterns": ["^node$"],
      "allowedVersions": "^22"
    }
  ]
}
