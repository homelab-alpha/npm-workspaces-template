{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", ":semanticCommits", ":rebaseStalePrs"],
  "dependencyDashboard": true,
  "osvVulnerabilityAlerts": true,
  "prConcurrentLimit": 0,
  "prHourlyLimit": 0,
  "timezone": "Europe/Amsterdam",
  "schedule": ["after 9am and before 5pm"],
  "rangeStrategy": "bump",
  "ignorePaths": ["docker/compose.prod.yml"],
  "assignees": ["homelab-alpha"],
  "automergeSchedule": ["after 9am and before 5pm on weekdays"],
  "automergeType": "squash",
  "packageRules": [
    {
      "description": "Never automerge major/minor",
      "matchUpdateTypes": ["major", "minor"],
      "automerge": false
    },
    {
      "description": "Automerge patch updates",
      "matchUpdateTypes": ["patch"],
      "automerge": true,
      "platformAutomerge": true
    },
    {
      "description": "Keep Node.js on major version 22",
      "matchPackageNames": ["node", "@types/node"],
      "matchManagers": ["npm", "nodenv", "dockerfile"],
      "allowedVersions": "^22.0.0"
    },
    {
      "description": "Label updates based on type and dependencie",
      "matchUpdateTypes": [
        "major",
        "minor",
        "patch",
        "pin",
        "pinDigest",
        "digest",
        "lockFileMaintenance",
        "rollback",
        "bump",
        "replacement"
      ],
      "addLabels": ["{{{updateType}}}", "{{{depName}}}"]
    },
    {
      "description": "Mark dev dependencies",
      "matchDepTypes": ["devDependencies"],
      "addLabels": ["dev dependencies"]
    }
  ]
}
