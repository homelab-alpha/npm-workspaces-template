#                ‚Ėą‚Ėą‚ēĒ‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ‚Ėą‚Ėą‚ēĒ‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ‚Ėą‚Ėą‚ēĎ                      #
#                ‚Ėą‚Ėą‚ēĎ‚ēö‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚ēĚ ‚Ėą‚Ėą‚ēĎ‚ēö‚Ėą‚Ėą‚ēĒ‚ēĚ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĎ                      #
#                ‚Ėą‚Ėą‚ēĎ ‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ     ‚Ėą‚Ėą‚ēĎ ‚ēö‚ēź‚ēĚ ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚ēĎ‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó                 #
#                ‚ēö‚ēź‚ēĚ  ‚ēö‚ēź‚ēź‚ēź‚ēĚ‚ēö‚ēź‚ēĚ     ‚ēö‚ēź‚ēĚ     ‚ēö‚ēź‚ēĚ‚ēö‚ēź‚ēĚ  ‚ēö‚ēź‚ēĚ ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ                 #
#                                                                              #
################################################################################

# === REGISTRY & AUTHENTICATION ===
# Enforce official registry and secure communication
registry=https://registry.npmjs.org/
strict-ssl=true
always-auth=true

# Prevent accidental public publishing of private work
access=restricted


# === SECURITY HARDENING ===
# Automatic vulnerability scanning on install
audit=true

# Block lifecycle scripts to prevent supply-chain attacks (pre/post-install)
ignore-scripts=true

# Disable system metrics collection to protect environment metadata
send-metrics=false

# Strict engine checks to ensure environment compatibility
engine-strict=true


# === DEPENDENCY MANAGEMENT ===
# Enforce version consistency (no ^ or ~)
save-exact=true

# Ensure lockfile usage and integrity
package-lock=true

# Prevent auto-install of peer dependencies to maintain a lean tree
auto-install-peers=false

# Disable optional dependencies to reduce attack surface
# Note: Enabling this might break platform-specific tools like fsevents on macOS
optional=false

# Enable bin-links for CLI tool execution (e.g., Vite, Prettier)
bin-links=true


# === NETWORK & PERFORMANCE ===
# Prefer local cache to minimize external network calls
prefer-offline=true

# Fast-fail on network hangs to detect suspicious interference
fetch-timeout=20000
fetch-retries=2


# === CLI OUTPUT & CI OPTIMIZATION ===
# Minimize noise and prevent update check network calls
loglevel=error
fund=false
progress=false
update-notifier=false
